# ====== Variables d'environnement (à renseigner dans Vercel → Settings → Environment Variables) ======
# Ne mettez JAMAIS ces valeurs dans le code ni sur GitHub. Ce fichier est un exemple sans secrets.

# --- Stripe ---
# Tableau de bord Stripe → Développeurs → Clés API
STRIPE_SECRET_KEY=sk_live_xxx
# Stripe → Développeurs → Webhooks → (votre endpoint) → Secret de signature
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Sécurité des bons cadeaux ---
# Chaîne aléatoire longue et secrète (sert à signer les QR codes pour les rendre infalsifiables).
# Générez-en une, par ex. : openssl rand -base64 32
VOUCHER_SECRET=remplacez-par-une-chaine-aleatoire-longue
# Code administrateur pour marquer un bon comme "utilisé" sur la page de vérification.
ADMIN_TOKEN=choisissez-un-code-admin-secret

# --- Envoi des emails (Resend : https://resend.com) ---
RESEND_API_KEY=re_xxx
# Adresse expéditrice (le domaine doit être vérifié dans Resend ; sinon utilisez onboarding@resend.dev pour tester)
FROM_EMAIL=Tignes Parapente <bons@tignes-parapente.com>
# Adresse qui reçoit une copie de chaque bon vendu (optionnel)
BUSINESS_EMAIL=contact@tignes-parapente.com

# --- Base de données (Vercel → Storage → Postgres : la variable est injectée automatiquement) ---
# POSTGRES_URL est ajoutée automatiquement par l'intégration Vercel Postgres.
POSTGRES_URL=postgres://...

# --- URL publique du site (pour les liens QR et les redirections) ---
PUBLIC_BASE_URL=https://www.tignes-parapente.com
